{
  "datasets": [
    {
      "name": "iam_metrics",
      "displayName": "IAM Security Metrics",
      "config": {
        "source": "identity.default.silver_iam_logs",
        "measures": [
          {
            "displayName": "Login Count",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "login_count",
            "expr": "COUNT(*)",
            "comment": "Total number of login attempts"
          },
          {
            "displayName": "Failed Logins",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "failed_logins",
            "expr": "COUNT(*) FILTER (WHERE login_status = 'Failed')",
            "comment": "Number of failed login attempts"
          },
          {
            "displayName": "Average Risk Score",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_risk_score",
            "expr": "AVG(risk_score)",
            "comment": "Average risk score across login attempts"
          },
          {
            "displayName": "Failed Login Rate",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "failed_login_rate",
            "expr": "SUM(CASE WHEN login_status = 'Failed' THEN 1.0 ELSE 0 END) / COUNT(*)",
            "comment": "Percentage of failed login attempts"
          }
        ],
        "version": "1.1",
        "comment": "Identity and Access Management security metrics for monitoring login activity, risk scores, department usage, device types, and time patterns",
        "dimensions": [
          {
            "name": "department",
            "expr": "department",
            "displayName": "Department",
            "comment": "Department name (HR, IT, Finance, Sales)"
          },
          {
            "name": "login_status",
            "expr": "login_status",
            "displayName": "Login Status",
            "comment": "Login outcome (Success or Failed)"
          },
          {
            "name": "username",
            "expr": "username",
            "displayName": "Username",
            "comment": "User identifier"
          },
          {
            "name": "device_type",
            "expr": "device_type",
            "displayName": "Device Type",
            "comment": "Type of device used for login (Desktop, Mobile, Tablet, Web)"
          },
          {
            "name": "login_hour",
            "expr": "HOUR(CAST(login_time AS TIMESTAMP))",
            "displayName": "Login Hour",
            "comment": "Hour of day when login occurred (0-23)"
          },
          {
            "name": "login_date",
            "expr": "DATE(CAST(login_time AS TIMESTAMP))",
            "displayName": "Login Date",
            "comment": "Date of login attempt"
          }
        ]
      }
    },
    {
      "name": "high_risk_users",
      "displayName": "High Risk Users",
      "queryLines": [
        "SELECT\n",
        "  username,\n",
        "  AVG(risk_score) as avg_risk_score\n",
        "FROM\n",
        "  identity.default.silver_iam_logs\n",
        "GROUP BY\n",
        "  username\n",
        "ORDER BY\n",
        "  avg_risk_score DESC\n",
        "LIMIT 20"
      ],
      "catalog": "identity",
      "schema": "default"
    }
  ],
